        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.svujais.flow"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "f7f65ba8-5569-4477-9fd7-c0c69f155ebe"
      }
    }
  }
}
